{
	"name": "atlas-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"wasm": "rm -rf ../atlas-web/static/pkg && wasm-pack build ../atlas-layout-wasm --target web --out-dir ../atlas-web/static/pkg",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format --write .",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test:unit": "bun test src/lib",
		"test": "bun run wasm && playwright test",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wasm-pack": "^0.15.0"
	},
	"trustedDependencies": [
		"wasm-pack"
	],
	"dependencies": {
		"graphology": "^0.26.0",
		"sigma": "^3.0.3"
	}
}
